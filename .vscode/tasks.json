    "version": "2.0.0",
    "tasks": [
        {
            "label": "Clean-Baggages",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "scripts/Clean-Baggages.ps1"
            ],
            "problemMatcher": [],
            "presentation": { "reveal": "silent" }
        },
        {
            "label": "OpenKNXproducer",
            "type": "shell",
            "command": "~/bin/OpenKNXproducer.exe",
            "args": [
                "create",
                "--Debug",
                "--HeaderFileName=include/knxprod.h",
                "src/ModbusGateway"
            ],
            "dependsOn": "Clean-Baggages",
            "problemMatcher": [],
            "group": "test"
        },
        {
            "label": "Build-Release",
            "type": "shell",
            "command": "scripts/Build-Release.ps1",
            "args": [],
            "problemMatcher": [],
            "group": "test"
        }
    ]
}#